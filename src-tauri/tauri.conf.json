{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeyGrats Local Sync",
  "version": "0.1.1",
  "identifier": "com.heygrats.localsync",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run web:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HeyGrats Local Sync",
        "width": 1040,
        "height": 860,
        "resizable": true,
        "maximizable": true,
        "minWidth": 900,
        "minHeight": 744
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
