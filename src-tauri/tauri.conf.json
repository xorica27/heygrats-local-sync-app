{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeyGrats Local Sync",
  "version": "0.1.0",
  "identifier": "com.heygrats.localsync",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run web:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HeyGrats Local Sync",
        "width": 1040,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
